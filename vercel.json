{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.0",
            "memory": 512,
            "maxDuration": 30
        }
    },
    "outputDirectory": "public",
    "buildCommand": "npm ci && npm run build",
    "routes": [
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
